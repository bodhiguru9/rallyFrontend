type EventDetailsScreenNavigationProp = NativeStackNavigationProp<
  RootStackParamList,
  'EventDetails'
>;

export const EventDetailsScreen: React.FC = () => {
  const navigation = useNavigation<EventDetailsScreenNavigationProp>();
  const insets = useSafeAreaInsets();

  const {
    event,
    isLoading,
    isAuthenticated,
    user,
    isOrganiser,
    guestsCount,
    setGuestsCount,
    isMembersModalVisible,
    totalPrice,
    exactPaidAmount,
    variant,
    buttonText,
    handleShare,
    handleSignIn,
    handleBookNow,
    handleBookEvent,
    handleCloseBookingModal,
    isBookingModalVisible,
    isBookingEvent,
    canCancelBooking,
    handleCancelBooking,
    isCancelBookingModalVisible,
    handleCloseCancelBookingModal,
    cancelBookingId,
    cancelVariant,
    handleCancelBookingSuccess,
    isLeavingEvent,
    handleOpenMembersModal,
    handleCloseMembersModal,
    showPayNow,
    handlePayNow,
    occurrenceStart,
    occurrenceEnd,
    isRegistrationEnded,
    eventId,
  } = useEventDetails();

  const pendingInvitation = event?.userJoinStatus?.hasRequest;

  if (isLoading) {
    return (
      <SafeAreaView style={styles.container}>
        <FlexView style={styles.loadingContainer}>
          {Platform.OS === 'ios' ? (
            <Video
              source={require('../../assets/images/loading-gifs/RALLLY_LOOP_LOADING_02_TRANSPARENT-cmprsd.mov')}
              style={styles.videoLoader}
              resizeMode={ResizeMode.CONTAIN}
              shouldPlay
              isLooping
              isMuted
            />
          ) : (
            <ActivityIndicator size="large" color="#000000" />
          )}
        </FlexView>
      </SafeAreaView>
    );
  }

  if (!event) {
    return null;
  }
