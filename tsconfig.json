{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "module": "ESNext",
    "types": ["jest"],
    "baseUrl": ".",
    "paths": {
      "@components": ["src/components"],
      "@components/*": ["src/components/*"],
      "@screens": ["src/screens"],
      "@screens/*": ["src/screens/*"],
      "@navigation": ["src/navigation"],
      "@navigation/*": ["src/navigation/*"],
      "@services": ["src/services"],
      "@services/*": ["src/services/*"],
      "@hooks": ["src/hooks"],
      "@hooks/*": ["src/hooks/*"],
      "@utils": ["src/utils"],
      "@utils/*": ["src/utils/*"],
      "@app-types": ["src/types"],
      "@app-types/*": ["src/types/*"],
      "@assets": ["src/assets"],
      "@assets/*": ["src/assets/*"],
      "@config": ["src/config"],
      "@config/*": ["src/config/*"],
      "@theme": ["src/theme"],
      "@theme/*": ["src/theme/*"],
      "@constants": ["src/constants"],
      "@constants/*": ["src/constants/*"],
      "@contexts": ["src/contexts"],
      "@contexts/*": ["src/contexts/*"],
      "@store": ["src/store"],
      "@store/*": ["src/store/*"],
      "@dev-tools": ["src/dev-tools"],
      "@dev-tools/*": ["src/dev-tools/*"],
      "@data": ["src/data"],
      "@data/*": ["src/data/*"],
      "@designSystem": ["src/DesignSystem"],
      "@designSystem/*": ["src/DesignSystem/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["**/*.ts", "**/*.tsx", "nativewind-env.d.ts"],
  "exclude": ["**/node_modules", "**/Pods", "android", "ios"]
}
